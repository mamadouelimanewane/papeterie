{
  "expo": {
    "name": "Papeterie Livreur",
    "slug": "papeterie-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A148C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.papeterie.driverapp",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Papeterie Livreur utilise votre localisation pour les livraisons.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Papeterie Livreur utilise votre localisation en arrière-plan pour le suivi en temps réel.",
        "NSCameraUsageDescription": "Papeterie Livreur utilise la caméra pour les documents d'identification.",
        "NSPhotoLibraryUsageDescription": "Papeterie Livreur accède à vos photos pour les documents."
      }
    },
    "android": {
      "package": "com.papeterie.driverapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A148C"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Papeterie Livreur utilise votre GPS pour les livraisons en temps réel.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A148C"
        }
      ]
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.papeterie.driverapp.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.papeterie.driverapp.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "e6039cfa-3344-40f1-bf1e-513525cc4b84"
      }
    },
    "owner": "mamadouelimane"
  }
}
